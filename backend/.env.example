# ==========================================
# Lidya Cultural Food Zone - Environment Variables
# ==========================================

# ------------------------------------------
# Server Configuration (Optional defaults)
# ------------------------------------------
# The environment the server is running in. Defaults to 'development'.
# Acceptable values: development, production, test
NODE_ENV=development

# The port the server will bind to. Defaults to 5000.
PORT=5000

# The URL where your frontend is deployed. Defaults to http://localhost:5173.
# IMPORTANT: In production, set this to your Vercel URL to avoid CORS errors.
FRONTEND_URL=http://localhost:5173

# ------------------------------------------
# Database Configuration (Required Secrets)
# ------------------------------------------
# The connection string for your PostgreSQL database (e.g., Neon).
DATABASE_URL=postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require

# ------------------------------------------
# Authentication Secrets (Required Secrets)
# ------------------------------------------
# A long, cryptographically secure random string used to sign access tokens.
JWT_SECRET=your-super-secret-access-token-key-here

# A long, cryptographically secure random string used to sign refresh tokens.
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-here
